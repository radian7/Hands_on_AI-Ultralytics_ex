# ---- Azure ----
subscription_id     = "00000000-0000-0000-0000-000000000000"
resource_group_name = "my-resource-group"
workspace_name      = "Workspace1"

# ---- Model ----
model_local_path = "../runs/detect/train/weights/best.torchscript"
model_name       = "torchscript-yolo-model"
model_version    = "1"

# ---- Endpoint ----
endpoint_name   = "torchscript-endpoint"
deployment_name = "torchscript-deploy-1"
instance_type   = "Standard_DS3_v2"
instance_count  = 1

# ---- Environment (curated PyTorch CPU) ----
curated_environment = "azureml://registries/azureml/environments/acpt-pytorch-2.2-cuda12.1/labels/latest"
