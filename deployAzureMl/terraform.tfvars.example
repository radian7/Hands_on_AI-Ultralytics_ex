# Skopiuj ten plik jako terraform.tfvars i uzupełnij wartości
# NIE commituj terraform.tfvars do repozytorium (dodaj do .gitignore)

subscription_id     = "<TWÓJ_SUBSCRIPTION_ID>"
resource_group_name = "<RESOURCE_GROUP_WORKSPACE1>"
location            = "West Europe"
workspace_name      = "Workspace1"

# ACR — nazwa musi być globalnie unikalna, tylko litery i cyfry
acr_name = "acronnxinference<sufiks>"

# Model
model_name    = "onnx-dotnet-model"
model_version = "1"

# Endpoint
endpoint_name   = "onnx-dotnet-endpoint"
deployment_name = "dotnet-blue"

# Obraz Docker z .NET API — uzupełnij po zbudowaniu i pushu
# Format: <acr_login_server>/onnx-api:<tag>
container_image = "acronnxinference<sufiks>.azurecr.io/onnx-dotnet-api:1.0.0"

# VM — CPU: Standard_DS3_v2 | GPU: Standard_NC6s_v3
instance_type  = "Standard_DS3_v2"
instance_count = 1

environment = "prod"

tags = {
  project    = "onnx-inference"
  runtime    = "dotnet"
  framework  = "onnx"
  managed_by = "opentofu"
}
